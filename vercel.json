{
  "version": 2,
  "builds": [
    {"src": "frontend/package.json", "use": "vercel/node"},
    {"src": "api/index.py", "use": "vercel-python"}
  ],
  "routes": [
    {"src": "/api/(.*)", "dest": "/api/index.py"},
    {"src": "/assets/(.*)", "dest": "/frontend/assets/$1"},
    {"src": "/(.*)", "dest": "/frontend/index.html"}
  ]
}